# Store real values only in QingLong protected environment variables.
CHECKIN_BASE_URL=https://www.nodeseek.com
CHECKIN_STATUS_PATH=/api/attendance/board?page=1
# fixed sends random=false; random sends random=true. Do not use a task command to override it.
CHECKIN_ATTENDANCE_MODE=fixed
CHECKIN_COOKIE=<REDACTED_COOKIE>
CHECKIN_ACCOUNT_NAME=default
# Multi-account alternative; use this instead of CHECKIN_COOKIE.
# CHECKIN_ACCOUNTS=[{"name":"account-a","cookie":"<REDACTED_COOKIE>"}]
CHECKIN_CONNECT_TIMEOUT=5
CHECKIN_READ_TIMEOUT=15
CHECKIN_MAX_RETRIES=2
CHECKIN_JITTER_MAX_SECONDS=0
CHECKIN_TIMEZONE=Asia/Shanghai
CHECKIN_NOTIFY_MODE=log
