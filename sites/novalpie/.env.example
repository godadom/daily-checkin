# Copy values into QingLong's protected environment store; never commit a populated .env.
CHECKIN_TOKEN=<REDACTED_TOKEN>
# Optional account alias (default: default):
# CHECKIN_ACCOUNT_NAME=default
# Alternative multi-account value (use instead of CHECKIN_TOKEN):
# CHECKIN_ACCOUNTS=[{"name":"account-a","token":"<REDACTED_TOKEN>"}]
# Optional overrides; built-in defaults are shown below:
# CHECKIN_CONNECT_TIMEOUT=5
# CHECKIN_READ_TIMEOUT=15
# CHECKIN_MAX_RETRIES=2
# CHECKIN_JITTER_MAX_SECONDS=0
# CHECKIN_TIMEZONE=Asia/Shanghai
# CHECKIN_NOTIFY_MODE=log
